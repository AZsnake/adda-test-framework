.env
.env.*
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json

# --- OS junk ---
Thumbs.db
desktop.ini
.DS_Store

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
.venv/
venv/

# --- Board-specific (package pins from schematics) ---
constraints/adda_io.xdc

# --- Licensed / confidential documentation ---
docs/schematics/
docs/specs/
docs/metrics/
docs/*.xlsx
docs/*.csv
docs/schematics/_*

